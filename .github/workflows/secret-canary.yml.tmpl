name: PROJECT_TOKEN Canary (ADR-0014 §3.5)

# One-shot canary that proves the PROJECT_TOKEN repo secret is BOTH:
#   1. Stored correctly (no whitespace / encoding corruption from `gh secret set`)
#   2. Alive & scoped (accepted by api.github.com/user with HTTP 200)
#
# Runs only on workflow_dispatch from scripts/dev-studio-init.sh during
# bootstrap. The init script triggers it, polls for completion, and aborts
# the whole bootstrap if conclusion != success. This catches the class of
# bugs where a local `$token` env-var ping passes but the secret bytes
# received by the runner are corrupted (BOM, CR, trailing whitespace).
#
# Owner: dev-studio-template
# Repo:  {{GITHUB_OWNER}}/{{GITHUB_REPO}}
# Why workflow_dispatch (not push): deterministic — init knows exactly
# which run_id to watch. See ADR-0014 §3.5.

on:
  workflow_dispatch:
    inputs:
      bootstrap_id:
        description: "Opaque correlation id from dev-studio-init.sh"
        required: false
        default: "manual"

jobs:
  canary:
    name: Verify PROJECT_TOKEN reaches runner intact
    runs-on: ubuntu-latest
    timeout-minutes: 2
    steps:
      - name: Ping api.github.com/user with secret PROJECT_TOKEN
        env:
          PROJECT_TOKEN: ${{ secrets.PROJECT_TOKEN }}
          BOOTSTRAP_ID: ${{ inputs.bootstrap_id }}
        run: |
          set -euo pipefail
          echo "::group::Canary preamble"
          echo "bootstrap_id=${BOOTSTRAP_ID}"
          if [ -z "${PROJECT_TOKEN:-}" ]; then
            echo "::error::PROJECT_TOKEN secret is empty on runner"
            exit 2
          fi
          tok_len="${#PROJECT_TOKEN}"
          echo "token_length=${tok_len}"
          # Length sanity: classic ghp_ PATs are 40 chars, fine-grained github_pat_
          # are 82+ chars. Anything shorter than 30 means corruption.
          if [ "$tok_len" -lt 30 ]; then
            echo "::error::PROJECT_TOKEN length=${tok_len} (too short — likely corrupted at secret write time)"
            exit 3
          fi
          echo "::endgroup::"

          echo "::group::Live API ping"
          http_code="$(curl -sS -o /tmp/body.json -w '%{http_code}' \
            --max-time 15 \
            -H "Authorization: Bearer ${PROJECT_TOKEN}" \
            -H "Accept: application/vnd.github+json" \
            https://api.github.com/user || echo "000")"
          echo "http_code=${http_code}"
          case "$http_code" in
            200)
              login="$(jq -r '.login // "?"' /tmp/body.json 2>/dev/null || echo "?")"
              echo "✅ PROJECT_TOKEN accepted by GitHub. Authenticated as: ${login}"
              ;;
            401)
              echo "::error::HTTP 401 Bad credentials — token rejected by GitHub. Secret bytes corrupted or PAT revoked. See ADR-0014 §3.5."
              exit 4
              ;;
            403)
              echo "::error::HTTP 403 — token lacks scope. Need repo + project on a classic PAT. See ADR-0014 §3.1."
              exit 5
              ;;
            000)
              echo "::error::Network error talking to api.github.com from runner."
              exit 6
              ;;
            *)
              echo "::error::Unexpected HTTP ${http_code} from api.github.com/user."
              exit 7
              ;;
          esac
          echo "::endgroup::"

          echo "::group::Projects v2 scope probe (graphql ping)"
          # Minimal viewer query to confirm `project` scope is actually live.
          # If scope is missing, GraphQL returns 200 with errors[] containing
          # "INSUFFICIENT_SCOPES" — curl still gets HTTP 200, so we parse body.
          gql_body="$(curl -sS \
            --max-time 15 \
            -H "Authorization: Bearer ${PROJECT_TOKEN}" \
            -H "Accept: application/vnd.github+json" \
            -X POST \
            -d '{"query":"query{viewer{login projectsV2(first:1){totalCount}}}"}' \
            https://api.github.com/graphql || echo '{"errors":[{"type":"NETWORK"}]}')"
          if echo "$gql_body" | jq -e '.errors // empty' >/dev/null 2>&1; then
            err_type="$(echo "$gql_body" | jq -r '.errors[0].type // .errors[0].message // "unknown"')"
            echo "::error::GraphQL probe failed: ${err_type}. Token likely missing 'project' scope. See ADR-0014 §3.1."
            exit 8
          fi
          total="$(echo "$gql_body" | jq -r '.data.viewer.projectsV2.totalCount // "?"')"
          echo "✅ GraphQL projectsV2 probe OK (totalCount=${total})"
          echo "::endgroup::"

          echo "Canary PASSED. PROJECT_TOKEN is intact, alive, and properly scoped."
