[build-system]
requires = ["setuptools>=68.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "atilcalc"
version = "0.1.0"
description = "{{PROJECT_NAME}} expression engine + CLI/HTTP surfaces, sister-pattern to AtilCalculator (ADR-0017 §engine ↔ UI separation)"
readme = "README.md"
requires-python = ">=3.11"
license = { file = "LICENSE" }
authors = [
    { name = "{{HUMAN_OWNER_NAME}}" },
]
keywords = ["calculator", "decimal", "expression-engine", "keyboard-first"]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Intended Audience :: Developers",
    "Intended Audience :: End Users/Desktop",
    "License :: OSI Approved :: MIT License",
    "Operating System :: POSIX :: Linux",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12",
    "Topic :: Scientific/Engineering :: Mathematics",
]

# Runtime dependencies pinned EXACT per ADR-0017 §Concrete stack doctrine.
# Engine is stdlib-only by design (engine ↔ UI separation); mpmath is the
# documented carve-out for transcendental functions (ADR-0019 amendment 2).
dependencies = [
    "mpmath==1.3.0",
]

# STORY-316 / Issue #316 — installable `atilcalc` console-script entry.
# Per ADR-0017 §Tech stack, CLI scaffolding is `typer` (declarative). The
# canonical entry point is `atilcalc.cli.main(argv)` — a stdlib-argparse
# implementation (typer can be swapped in later when REPL mode needs it).
# Contract: `pip install atilcalc` (or `pip install -e .[dev]` in dev) creates
# an `atilcalc` console-script on PATH.
[project.scripts]
atilcalc = "atilcalc.cli:main"

[project.optional-dependencies]
# Dev tooling (test surface, lint, type check). NOT installed in production.
# Pinned EXACT per ADR-0017 doctrine ("Pin dependency versions exactly").
dev = [
    "pytest==8.3.4",
    "pytest-cov==6.0.0",
    "ruff==0.8.6",
    "mypy==1.13.0",
]

[project.urls]
Homepage = "https://github.com/{{GITHUB_OWNER}}/{{GITHUB_REPO}}"
Issues = "https://github.com/{{GITHUB_OWNER}}/{{GITHUB_REPO}}/issues"

# ============================================================================
# Tooling configuration
# ============================================================================

[tool.setuptools.packages.find]
where = ["src"]

[tool.setuptools.package-dir]
"" = "src"

# ----------------------------------------------------------------------------
# pytest configuration
# ----------------------------------------------------------------------------

[tool.pytest.ini_options]
minversion = "8.0"
addopts = [
    "-ra",                  # show summary of all fails/short info
    "--strict-markers",     # fail on unknown markers
    "--strict-config",      # fail on unknown config keys
    "--showlocals",         # show local vars in tracebacks
    "--tb=short",           # shorter traceback format
]
testpaths = ["tests"]
pythonpath = ["src"]
markers = [
    "slow: marks tests as slow (deselect with '-m \"not slow\"')",
    "integration: marks tests as integration tests (require external resources)",
]

# ----------------------------------------------------------------------------
# coverage configuration (pytest-cov)
# ----------------------------------------------------------------------------

[tool.coverage.run]
branch = true
source = ["src/atilcalc"]
omit = [
    "src/atilcalc/__init__.py",
    "src/atilcalc/*/__init__.py",
]

[tool.coverage.report]
precision = 1
show_missing = true
skip_covered = false

# ----------------------------------------------------------------------------
# ruff configuration (lint + format)
# ----------------------------------------------------------------------------

[tool.ruff]
line-length = 100
target-version = "py311"
src = ["src", "tests"]

[tool.ruff.lint]
select = [
    "E",    # pycodestyle errors
    "W",    # pycodestyle warnings
    "F",    # pyflakes
    "I",    # isort
    "B",    # flake8-bugbear
    "UP",   # pyupgrade
    "N",    # pep8-naming
    "SIM",  # flake8-simplify
    "RUF",  # ruff-specific rules
]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"

# ----------------------------------------------------------------------------
# mypy configuration
# ----------------------------------------------------------------------------

# Per ADR-0017 §Concrete stack: mypy --strict on engine module only.
# cli/ and api/ stay permissive (Typer decorator magic, FastAPI pydantic models).

[tool.mypy]
python_version = "3.11"
mypy_path = "src"
check_untyped_defs = false
disallow_untyped_defs = false
warn_unused_ignores = true
warn_redundant_casts = true
warn_return_any = true
no_implicit_optional = true
show_error_codes = true
show_column_numbers = true

[[tool.mypy.overrides]]
# Engine module: strict typing (load-bearing per ADR-0017)
module = ["atilcalc.engine", "atilcalc.engine.*"]
strict = true
disallow_untyped_defs = true
disallow_any_generics = true
disallow_any_unimported = true
warn_unreachable = true
